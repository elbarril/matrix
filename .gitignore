# Matrix Intelligence Engine - Git Ignore

# Project repos (pulled on demand)
clients/

# Brain symlink (created in active projects)
_brain

# Sensitive data
brain/state/checkpoints/*
brain/state/sessions/
brain/state/*.yaml
brain/config.yaml
.context.yaml

# Generated adapter artifacts (Trainman build output)
adapters/*/generated/

# The Hardline event inbox (per-machine, may carry transient data)
modules/hardline/inbox.log

# Federated ship corpora (per-machine)
brain/subsystems/*/corpus/

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~
.vscode/
.idea/

*.backup
# Python cache
__pycache__/
*.pyc
