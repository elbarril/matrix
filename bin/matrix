#!/bin/bash

# Matrix CLI — Layer 1 orchestrator (CLI-agnostic)
# Manages registry, projects, the warm-project set, checkpoints, the Link
# ledger, Seraph hooks, and the Trainman build. It NEVER invokes agents.
# Version 2.0.0

set -euo pipefail

# Colors
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; NC='\033[0m'

# --- Robust root resolution (_brain-aware, with traversal fallback) ---------
resolve_root() {
    # 1) If a _brain symlink exists in cwd, the Matrix root is its parent.
    if [[ -L "_brain" ]]; then
        local brain_path; brain_path="$(readlink -f _brain)"
        dirname "$brain_path"; return 0
    fi
    # 2) Walk up from the script location until brain/ + AGENTS.md are found.
    local dir; dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
    while [[ "$dir" != "/" ]]; do
        if [[ -d "$dir/brain" && -f "$dir/AGENTS.md" ]]; then echo "$dir"; return 0; fi
        dir="$(dirname "$dir")"
    done
    # 3) Last resort: parent of bin/.
    cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd
}

MATRIX_DIR="$(resolve_root)"
REGISTRY_FILE="$MATRIX_DIR/.registry.json"
CONTEXT_FILE="$MATRIX_DIR/.context.yaml"
BRAIN_DIR="$MATRIX_DIR/brain"
STATE_DIR="$BRAIN_DIR/state"
CLIENTS_DIR="$MATRIX_DIR/clients"
WORKSPACE_FILE="$STATE_DIR/workspace.yaml"
ACTIVITY_LOG="$STATE_DIR/activity.log"
CHECKPOINTS_FILE="$STATE_DIR/checkpoints.jsonl"
HOOKS_DIR="$MATRIX_DIR/hooks"

log_info()    { echo -e "${BLUE}[MATRIX]${NC} $1"; }
log_success() { echo -e "${GREEN}[MATRIX]${NC} $1"; }
log_warning() { echo -e "${YELLOW}[MATRIX]${NC} $1"; }
log_error()   { echo -e "${RED}[MATRIX]${NC} $1"; }

# --- Init -------------------------------------------------------------------
init_registry() {
    [[ -f "$REGISTRY_FILE" ]] || echo '{"projects": [], "created": "'$(date -Iseconds)'", "version": "2.0.0"}' > "$REGISTRY_FILE"
}
init_context() {
    [[ -f "$CONTEXT_FILE" ]] || cat > "$CONTEXT_FILE" << 'EOF'
# Matrix Active Project Context (primary binding)
active_project: null
active_project_path: null
last_updated: null
session_id: null
EOF
}
init_state() {
    mkdir -p "$STATE_DIR/sessions"
    [[ -f "$ACTIVITY_LOG" ]] || : > "$ACTIVITY_LOG"
    [[ -f "$CHECKPOINTS_FILE" ]] || : > "$CHECKPOINTS_FILE"
    [[ -f "$WORKSPACE_FILE" ]] || cat > "$WORKSPACE_FILE" << 'EOF'
# Matrix Workspace State — the SET of warm projects (multi-project)
active_projects: []
last_updated: null
system_status: "initialized"
EOF
}

# --- Link ledger ------------------------------------------------------------
# Append an event: link_append <event> <subject> <detail...>
link_append() {
    init_state
    local event="$1"; shift
    local subject="${1:-matrix}"; shift || true
    local detail="$*"
    printf '%s | %-12s | %-16s | %s\n' "$(date -Iseconds)" "$event" "$subject" "$detail" >> "$ACTIVITY_LOG"
}

read_registry() { init_registry; jq -r '.projects[] | "\(.name):\(.path):\(.type)"' "$REGISTRY_FILE" 2>/dev/null || echo ""; }
read_context()  { init_context; grep "active_project:" "$CONTEXT_FILE" | head -1 | cut -d' ' -f2 || echo "null"; }

update_context() {
    local project="$1" path="$2"; path="${path%/}"
    sed -i "s|active_project:.*|active_project: $project|" "$CONTEXT_FILE"
    sed -i "s|active_project_path:.*|active_project_path: $path|" "$CONTEXT_FILE"
    sed -i "s|last_updated:.*|last_updated: $(date -Iseconds)|" "$CONTEXT_FILE"
}

# --- Project registry -------------------------------------------------------
add_project() {
    local name="$1" path_or_url="${2:-}"
    [[ -z "$name" ]] && { log_error "Usage: matrix add <name> [path-or-url]"; return 1; }
    if [[ -z "$path_or_url" ]]; then
        local current_dir; current_dir="$(pwd)"
        log_info "No path provided. Current directory: $current_dir"
        echo -n "Use this path? [y/N]: "; read -r r
        [[ "$r" =~ ^[Yy]$ ]] || { log_warning "Cancelled"; return 1; }
        path_or_url="$current_dir"
    fi
    read_registry | grep -q "^$name:" && { log_error "Project '$name' already exists"; return 1; }
    local type="local"
    [[ "$path_or_url" =~ ^https?:// || "$path_or_url" =~ ^git@ ]] && type="remote"
    [[ "$type" == "local" ]] && path_or_url="${path_or_url%/}"
    local tmp; tmp="$(mktemp)"
    jq --arg n "$name" --arg p "$path_or_url" --arg t "$type" \
       '.projects += [{"name": $n, "path": $p, "type": $t, "added": "'$(date -Iseconds)'"}]' \
       "$REGISTRY_FILE" > "$tmp" && mv "$tmp" "$REGISTRY_FILE"
    link_append "project:add" "$name" "$path_or_url"
    log_success "Added project '$name'"
}

list_projects() {
    log_info "Known projects:"; echo
    local projects; projects="$(read_registry)"
    [[ -z "$projects" ]] && { echo "  No projects registered"; return; }
    local active; active="$(read_context)"
    while IFS=: read -r name path type; do
        if [[ "$active" == "$name" ]]; then echo "  ✓ $name ($type) - $path [primary]"
        else echo "    $name ($type) - $path"; fi
    done <<< "$projects"
}

resolve_project_path() {
    local name="$1"
    local info; info="$(read_registry | grep "^$name:" | head -1)"
    [[ -z "$info" ]] && return 1
    local p; p="$(echo "$info" | cut -d: -f2)"
    p="${p/#\~/$HOME}"; echo "${p%/}"
}

select_project() {
    local name="$1"
    [[ -z "$name" ]] && { log_error "Usage: matrix select <name>"; return 1; }
    local info; info="$(read_registry | grep "^$name:" | head -1)"
    [[ -z "$info" ]] && { log_error "Project '$name' not found"; return 1; }
    IFS=: read -r pn pp pt <<< "$info"
    local active; active="$(read_context)"
    [[ "$active" != "null" && -n "$active" && "$active" != "$name" ]] && deselect_project
    pp="${pp/#\~/$HOME}"; pp="${pp%/}"
    if [[ "$pt" == "remote" ]]; then
        local dir="$CLIENTS_DIR/$name"
        [[ -d "$dir" ]] || { log_info "Cloning '$name'..."; mkdir -p "$CLIENTS_DIR"; git clone "$pp" "$dir"; }
        pp="$dir"
    fi
    [[ -d "$pp" ]] || { log_error "Path '$pp' does not exist"; return 1; }
    local link="$pp/_brain"
    [[ -L "$link" ]] && rm "$link"
    [[ -e "$link" ]] && { log_error "'_brain' exists and is not a symlink"; return 1; }
    ln -sf "$BRAIN_DIR" "$link"
    update_context "$name" "$pp"
    link_append "project:select" "$name" "$pp"
    log_success "Selected primary project '$name' (symlink: $link)"
}

deselect_project() {
    local active; active="$(read_context)"
    [[ "$active" == "null" || -z "$active" ]] && { log_warning "No active project"; return; }
    local ap; ap="$(grep "active_project_path:" "$CONTEXT_FILE" | cut -d' ' -f2)"; ap="${ap/#\~/$HOME}"; ap="${ap%/}"
    [[ -n "$ap" && -L "$ap/_brain" ]] && rm "$ap/_brain"
    update_context "null" "null"
    link_append "project:deselect" "$active" ""
    log_success "Deselected '$active'"
}

# --- Multi-project warm set -------------------------------------------------
work_project() {
    local name="$1"
    [[ -z "$name" ]] && { log_error "Usage: matrix work <name>"; return 1; }
    local path; path="$(resolve_project_path "$name")" || { log_error "Project '$name' not found"; return 1; }
    init_state
    grep -q "name: $name$" "$WORKSPACE_FILE" 2>/dev/null && { log_warning "'$name' already warm"; return 0; }
    # Insert before the last_updated line.
    local ts; ts="$(date -Iseconds)"
    local tmp; tmp="$(mktemp)"
    awk -v n="$name" -v p="$path" -v ts="$ts" '
        /^active_projects:/ && $0 ~ /\[\]/ { print "active_projects:"; print "  - name: " n; print "    path: " p; print "    activated: " ts; next }
        /^last_updated:/ { print "last_updated: \"" ts "\""; next }
        { print }
    ' "$WORKSPACE_FILE" > "$tmp"
    # If the set was non-empty, the awk above only handles the empty case; handle non-empty by append.
    if grep -q "name: $name$" "$tmp"; then mv "$tmp" "$WORKSPACE_FILE"; else
        rm -f "$tmp"
        # Append under active_projects: (non-empty list)
        sed -i "/^active_projects:/a\\  - name: $name\\n    path: $path\\n    activated: $ts" "$WORKSPACE_FILE"
        sed -i "s|^last_updated:.*|last_updated: \"$ts\"|" "$WORKSPACE_FILE"
    fi
    link_append "project:work" "$name" "$path"
    log_success "Warmed '$name' into the active set"
}

unwork_project() {
    local name="$1"
    [[ -z "$name" ]] && { log_error "Usage: matrix unwork <name>"; return 1; }
    init_state
    # Remove the 3-line block for this project.
    sed -i "/^  - name: $name$/,+2d" "$WORKSPACE_FILE"
    # If list is now empty, normalize.
    grep -q "^  - name:" "$WORKSPACE_FILE" || sed -i "s|^active_projects:.*|active_projects: []|" "$WORKSPACE_FILE"
    sed -i "s|^last_updated:.*|last_updated: \"$(date -Iseconds)\"|" "$WORKSPACE_FILE"
    link_append "project:unwork" "$name" ""
    log_success "Removed '$name' from the active set"
}

show_workspace() {
    init_state
    log_info "Warm project set:"; echo
    if grep -q "^  - name:" "$WORKSPACE_FILE"; then
        grep "^  - name:" "$WORKSPACE_FILE" | sed 's/  - name:/   •/'
    else
        echo "   (empty) — use 'matrix work <name>'"
    fi
}

# --- Status -----------------------------------------------------------------
show_status() {
    log_info "Matrix Status"; echo
    local active; active="$(read_context)"
    if [[ "$active" != "null" && -n "$active" ]]; then
        local ap; ap="$(grep "active_project_path:" "$CONTEXT_FILE" | cut -d' ' -f2)"; ap="${ap/#\~/$HOME}"; ap="${ap%/}"
        echo "Primary project: $active"
        echo "Path: $ap"
        if [[ -L "$ap/_brain" ]]; then echo "Brain link: ✓ active"; else echo "Brain link: ✗ broken"; fi
    else
        echo "Primary project: none"
    fi
    echo
    echo "Warm set: $(grep -c '^  - name:' "$WORKSPACE_FILE" 2>/dev/null || echo 0) project(s)"
    echo "Registered: $(read_registry | grep -c . || echo 0) project(s)"
    echo
    if [[ -s "$CHECKPOINTS_FILE" ]]; then
        echo "Recent checkpoints:"
        tail -n 3 "$CHECKPOINTS_FILE" | jq -r '"  " + .timestamp + " — " + .note' 2>/dev/null || true
    fi
    echo
    if [[ -s "$ACTIVITY_LOG" ]]; then
        echo "Recent Link events:"
        tail -n 3 "$ACTIVITY_LOG" | sed 's/^/  /'
    fi
}

# --- Checkpoints ------------------------------------------------------------
write_checkpoint() {
    local note="$1"
    [[ -z "$note" ]] && { log_error "Usage: matrix checkpoint \"<note>\""; return 1; }
    init_state
    local ts; ts="$(date -Iseconds)"
    local active; active="$(read_context)"
    jq -n -c --arg ts "$ts" --arg user "Emiliano" --arg proj "$active" --arg note "$note" \
        '{timestamp:$ts,user:$user,project:$proj,note:$note,context:{active_agents:[],current_focus:"",blockers:[],next_actions:[]}}' \
        >> "$CHECKPOINTS_FILE"
    link_append "checkpoint" "$active" "$note"
    log_success "Checkpoint written"
}

show_activity() {
    init_state
    local n="${1:-20}"
    log_info "Link ledger (last $n):"; echo
    tail -n "$n" "$ACTIVITY_LOG" | sed 's/^/  /'
}

# --- Seraph hooks -----------------------------------------------------------
run_hook() {
    local name="$1"; shift || true
    local hook="$HOOKS_DIR/$name.py"
    [[ -f "$hook" ]] || { log_error "Hook '$name' not found at $hook"; return 1; }
    MATRIX_ROOT="$MATRIX_DIR" python3 "$hook" "$@"
}

# --- Trainman build ---------------------------------------------------------
build_target() {
    local target=""
    for arg in "$@"; do case "$arg" in --target=*) target="${arg#*=}";; esac; done
    [[ -z "$target" ]] && { log_error "Usage: matrix build --target=<devin|claude|...>"; return 1; }
    local builder="$MATRIX_DIR/adapters/$target/build.sh"
    if [[ -x "$builder" ]]; then
        log_info "Trainman: building artifacts for '$target'..."
        MATRIX_ROOT="$MATRIX_DIR" "$builder"
        link_append "build" "$target" "artifacts generated"
    else
        log_warning "Trainman: no adapter builder at $builder (not implemented yet for '$target')."
        return 1
    fi
}

show_help() {
    cat << 'EOF'
Matrix CLI — Layer 1 orchestrator (CLI-agnostic)

Usage: matrix <command> [args]

Projects:
  list                    List all registered projects
  add <name> [path]       Register a project (path optional → current dir)
  select <name>           Set primary active project + create _brain symlink
  deselect                Clear primary active project + remove symlink

Multi-project (warm set):
  work <name>             Warm a project into the active set
  unwork <name>           Remove a project from the active set
  workspace               Show the warm project set

State & telemetry:
  status                  Show current Matrix status
  checkpoint "<note>"     Write a timestamped checkpoint (+ Link entry)
  activity [n]            Show last n Link ledger events (default 20)

Enforcement & adapters:
  hooks <name> [json]     Run a Seraph hook (pre_activation_check, validate_phase_close, post_run_audit)
  build --target=<cli>    Trainman: generate native artifacts for a CLI
  help                    Show this help
EOF
}

main() {
    case "${1:-}" in
        list)       list_projects ;;
        add)        add_project "${2:-}" "${3:-}" ;;
        select)     select_project "${2:-}" ;;
        deselect)   deselect_project ;;
        work)       work_project "${2:-}" ;;
        unwork)     unwork_project "${2:-}" ;;
        workspace)  show_workspace ;;
        status)     show_status ;;
        checkpoint) write_checkpoint "${2:-}" ;;
        activity)   show_activity "${2:-}" ;;
        hooks)      shift; run_hook "$@" ;;
        build)      shift; build_target "$@" ;;
        help|--help|-h) show_help ;;
        "") log_error "No command. Use 'matrix help'."; exit 1 ;;
        *)  log_error "Unknown command: $1"; echo "Use 'matrix help'."; exit 1 ;;
    esac
}

command -v jq >/dev/null 2>&1 || { log_error "jq is required but not installed."; exit 1; }
main "$@"
